# Aura configuration.
# Copy to ".env" and fill in, or export these in your shell / hosting platform.
#
# When CEREBRAS_API_KEY is unset, Aura runs in MOCK mode: the locator returns a
# deterministic spiral so the full client + haptic/speech loop works offline.

# Required for live inference.
CEREBRAS_API_KEY=

# Optional overrides (defaults shown).
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1/chat/completions
CEREBRAS_MODEL=gemma-4-31b

# HTTP port.
PORT=3000
