{
  "name": "aura",
  "version": "1.0.0",
  "description": "Aura — an automated visual monitoring platform. Give a phone camera a mission and an action prompt; Gemma vision (on Cerebras) decides each scan cycle whether to alert and announces the response. Runs on Cloudflare Workers (Hono).",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "node scripts/build-training.js",
    "predev": "node scripts/gen-icons.js && node scripts/build-training.js",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "predeploy": "node scripts/gen-icons.js && node scripts/build-training.js",
    "deploy": "wrangler deploy",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ax-llm/ax": "^22.0.7",
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "wrangler": "^4.20.0"
  },
  "license": "GPL-3.0"
}
